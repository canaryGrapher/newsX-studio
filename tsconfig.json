{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "/tmp/nx-dist/types/**/*.ts",
    "/tmp/nx-dist/dev/types/**/*.ts",
    "/tmp/nx-dist2/types/**/*.ts",
    "/tmp/nx-dist2/dev/types/**/*.ts",
    "/sessions/blissful-confident-mendel/mnt/outputs/nxbuild/types/**/*.ts",
    "/sessions/blissful-confident-mendel/mnt/outputs/nxbuild/dev/types/**/*.ts",
    "/tmp/newsx-build/types/**/*.ts",
    "/tmp/newsx-build/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
